{
  "name": "regibyte-clj-interpreter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "bun:repl": "bun run src/bin/cli.ts repl",
    "bun:run": "bun run src/bin/cli.ts run",
    "bun:build-cli": "bun build --compile src/bin/cli.ts --outfile cli",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "gen:core-source": "node scripts/gen-core-source.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "monaco-editor": "^0.55.1"
  }
}
